Attribute VB_Name = "REL_Pedido_Orcamento"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Option Explicit

Dim rPd As ADODB.Recordset
Dim rCl As ADODB.Recordset
Dim rIt As ADODB.Recordset
Dim rPc As ADODB.Recordset
Dim rFu As ADODB.Recordset

Public Sub loadPedidos(Pedido As Long)
   'colocar o nome da maquina na barra de status
   Dim var_Impressora As String
   Dim oIni As Ini
   
   Dim Cont As Long
   Dim wValorFormatado As String
   
   Set oIni = New Ini
   oIni.Arquivo = appPathApp & "config.ini"
   var_Impressora = oIni.LerTexto("IMPRESSORA_FOLHA", "impressora")
   Set oIni = Nothing
   
   Set rPd = dbData.OpenRecordset("SELECT * FROM pedidos WHERE (cod_pedido = " & Pedido & ");")
   Set rCl = dbData.OpenRecordset("SELECT * FROM cliente WHERE (codigo = " & rPd("cod_cliente") & ");")
   Set rIt = dbData.OpenRecordset("SELECT produtos.fabricante AS var_fab, pedidos_itens.codigo, pedidos_itens.cod_produto, produtos.descricao, pedidos_itens.preco, pedidos_itens.quantidade, (pedidos_itens.preco * pedidos_itens.quantidade) as total FROM produtos INNER JOIN pedidos_itens ON produtos.codigo = pedidos_itens.cod_produto WHERE (pedidos_itens.cod_pedido = " & Pedido & ") ORDER BY pedidos_itens.codigo DESC;")
   Set rPc = dbData.OpenRecordset("SELECT * FROM parcelas WHERE (cod_pedido = " & Pedido & ") ORDER BY numero;")
   Set rFu = dbData.OpenRecordset("SELECT * FROM funcionario WHERE (codigo = " & rPd("cod_funcionario") & ");")
   
   txtNumero.Caption = "Nş " & Format(PDV.txtCodPedido.Text, "000000")
   
   If rPd("cod_cliente") = 0 Then Exit Sub
   
   'DADOS DO CLIENTE
   txtCliente.Caption = rCl("nome")
   'txtEnd.Caption = IIf(IsNull(rsCliente![ENDERECO]) = True, "", rsCliente![ENDERECO]) & " - " & IIf(IsNull(rsCliente!BAIRRO) = True, "", rsCliente!BAIRRO)
   'txtRef.Caption = IIf(IsNull(rsCliente!ponto_de_referencia) = True, "", rsCliente!ponto_de_referencia)
   'txtCidade.Caption = IIf(IsNull(rsCliente!cidade) = True, "", rsCliente!cidade) & "-" & IIf(IsNull(rsCliente!estado) = True, "", rsCliente!estado) & "   FONE: " & IIf(IsNull(rsCliente!TELEFONE1) = True, "", rsCliente!TELEFONE1)
   'txtCPF.Caption = IIf(IsNull(rsCliente!cpf) = True, "", rsCliente!cpf)
   'txtRG.Caption = IIf(IsNull(rsCliente!CI) = True, "", rsCliente!CI)

   'DADOS DO PEDIDO
   txtData.Caption = String(1, " ") + Format(rPd("data_compra"), "dd/mm/yy")
   txtVendedor.Caption = rFu("nome")
   txtValidade.Caption = "VALIDADE: " & Format(rPd("validade"), "DD/MM/YY")
   
   'DADOS DO FINANCEIRO
   'Á VISTA
   rfVista.Caption = "TOTAL: " & Format(rPd("total"), ocMONEY)
   
   If IsNull(rPd("valor_desc")) Then
      wValorFormatado = "0,00"
   Else
      If rPd("tipo_desc") = "R" Then
         wValorFormatado = Format(rPd("valor_desc"), ocMONEY)
      Else
         wValorFormatado = FormatNumber(rPd("valor_desc"), 2) & "%"
      End If
   End If
   
   rfDescVista.Caption = "DESC: " & wValorFormatado
   
   'Á PRAZO
   rfPrazo.Caption = "TOTAL: " & Format(rPd("subtotal"), ocMONEY)
   rfDescPrazo.Caption = "DESC: " & FormatNumber(0, 2) & "%"
   
   'INSIRO OS ITENS
   If Not rIt.EOF Then rIt.MoveLast
   If Not rIt.BOF Then rIt.MoveFirst
   
   Relatorio.NumeroRegistros = Round((rIt.RecordCount / 17) + 0.49)
   'Relatorio.NomeImpressora = var_Impressora
   Relatorio.Ativar
End Sub

Private Sub Form_Load()
   On Error GoTo TrataErro
   Dim sSQL As String
   Dim r As ADODB.Recordset
   
   sSQL = "SELECT TOP 1 * FROM empresa ORDER BY fantasia;"
   Set r = dbData.OpenRecordset(sSQL)
   
   rf1.Caption = r("fantasia")
   rf2.Caption = r("razao")
   rf3.Caption = r("endereco") & ", " & r("cidade") & "-" & r("estado")
   rf4.Caption = "CNPJ: " & r("cnpj") & " - IE: " & r("ie") & " - TELEFONE: " & r("telefone")
   
   If Not IsNull(r("caminho")) Then
      If Dir$(r("caminho")) <> "" Then Set imgLogo.Picture = LoadPicture(r("caminho"))
   End If
   
   If r.State <> 0 Then r.Close
   Set r = Nothing
   Exit Sub
   
TrataErro:
End Sub

Private Sub Form_Unload(Cancel As Integer)
   If Not rPd Is Nothing Then If rPd.State <> 0 Then rPd.Close
   If Not rCl Is Nothing Then If rCl.State <> 0 Then rCl.Close
   If Not rIt Is Nothing Then If rIt.State <> 0 Then rIt.Close
   If Not rPc Is Nothing Then If rPc.State <> 0 Then rPc.Close
   If Not rFu Is Nothing Then If rFu.State <> 0 Then rFu.Close
End Sub

Private Sub Relatorio_IniciarSecao(ByVal Secao As ReportX.TSecao, ByVal Ordem As Byte)
   Dim i As Integer
   
   'produtos do pedido
   For i = 0 To 16
      txtDesc(i).Caption = ""
      txtQuant(i).Caption = ""
      txtUnit(i).Caption = ""
      txtTot(i).Caption = ""
      
      If Not rIt.EOF Then
         txtDesc(i).Caption = String(1, " ") + rIt("descricao")
         txtQuant(i).Caption = rIt("quantidade")
         txtUnit(i).Caption = Format(rIt("preco"), "##,##0.00")
         txtTot(i).Caption = Format((rIt("preco") * rIt("quantidade")), ocMONEY)
         
         rIt.MoveNext
      End If
   Next
   Exit Sub
End Sub

